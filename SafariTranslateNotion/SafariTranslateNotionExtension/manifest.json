{
  "manifest_version": 3,
  "name": "Translate & Save to Notion",
  "version": "1.0.0",
  "description": "Translate selected text with DeepSeek, save vocabulary to Notion, and export AO3 works to Obsidian markdown.",
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "scripting",
    "nativeMessaging",
    "notifications"
  ],
  "host_permissions": [
    "https://api.deepseek.com/*",
    "https://api.notion.com/*",
    "https://*.notion.com/*",
    "<all_urls>"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src https://api.deepseek.com https://api.notion.com https://*.notion.com"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["ao3-export.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "options_ui": {
    "page": "options.html"
  },
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "64": "images/icon-64.png",
    "96": "images/icon-96.png",
    "128": "images/icon-128.png"
  },
  "action": {
    "default_title": "Translate & Save to Notion",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon-16.png",
      "19": "images/icon-19.png",
      "32": "images/icon-32.png",
      "38": "images/icon-38.png"
    }
  }
}
